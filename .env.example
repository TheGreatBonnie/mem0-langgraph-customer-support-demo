# Copy to .env and fill in real keys when you want live Mem0/OpenRouter calls.
OPENROUTER_API_KEY=
MEM0_API_KEY=

# Optional knobs.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
SUPPORT_AGENT_APP_ID=memory-first-support-demo
SUPPORT_AGENT_ID=memory-first-support-agent

# auto = use live services when keys exist, otherwise local demo fallbacks.
# true = always use local demo fallbacks.
# false = require live service clients.
SUPPORT_AGENT_OFFLINE_MODE=auto

# Mem0 retrieval tuning (live mode).
MEM0_ENABLE_GRAPH=true
MEM0_SEARCH_RERANK=true
MEM0_SEARCH_KEYWORD=true
MEM0_SEARCH_THRESHOLD=0.3
MEM0_THREAD_TOP_K=3
MEM0_PROFILE_TOP_K=5
